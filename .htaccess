# =============================================
# Lapak Gaming Marketplace - Root .htaccess
# Security & Routing Configuration
# =============================================

# Disable Directory Listing (Prevent "Index of" browsing)
Options -Indexes -MultiViews

# Enable Rewrite Engine
RewriteEngine On

# Force HTTPS (Production) - Uncomment setelah SSL installed
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect all requests to public/index.php
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]

# Block access to sensitive directories
RewriteRule ^(app|config|database|routes|vendor|storage)/ - [F,L]

# Protect sensitive files
<FilesMatch "^(\.env|\.htaccess|\.git|database\.sql|composer\.json|composer\.lock|README\.md|QUICKSTART\.md|API_TESTING\.md|DEPLOYMENT_CHECKLIST\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect .php files in root and config directories
<FilesMatch "^(config|vendor|app)/.*\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security Headers
<IfModule mod_headers.c>
    # Prevent MIME sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Clickjacking protection
    Header set X-Frame-Options "SAMEORIGIN"
    
    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove server signature
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# Disable server signature
ServerSignature Off

# Custom Error Pages (Optional - create these pages in public/ if needed)
# ErrorDocument 403 /public/403.html
# ErrorDocument 404 /public/404.html
# ErrorDocument 500 /public/500.html
