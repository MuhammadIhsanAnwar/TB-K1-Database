# EditorConfig - Coding Style Configuration
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Apache Configuration Files
[.htaccess]
indent_size = 4

[*.php]
indent_size = 4

[*.js]
indent_size = 2

[*.json]
indent_size = 2

[*.html]
indent_size = 2

[*.css]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sql]
indent_size = 4
